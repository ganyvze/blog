<section class="mx-auto mt-12 px-0 w-full max-w-[var(--content-width)]">
    <div id="giscus-container"></div>
</section>

<script is:inline>
    // 状态锁，防止重复加载
    let giscusLoaded = false;

    // 1. 核心：更可靠的主题检测函数
    function getGiscusTheme() {
        const isDark = document.documentElement.classList.contains('dark') || 
                       document.documentElement.getAttribute('data-theme') === 'dark' ||
                       localStorage.getItem('theme') === 'dark';
        return isDark ? 'transparent_dark' : 'light';
    }

    // 2. 动态加载 Giscus
    function loadGiscus() {
        if (giscusLoaded) return; // 避免重复加载
        
        const container = document.getElementById('giscus-container');
        if (!container) return;

        const currentTheme = getGiscusTheme();
        const script = document.createElement('script');
        script.src = 'https://giscus.app/client.js';
        script.setAttribute('data-repo', 'ganyvze/blog');
        script.setAttribute('data-repo-id', 'R_kgDOR_FN1Q');
        script.setAttribute('data-category', 'Announcements');
        script.setAttribute('data-category-id', 'DIC_kwDOR_FN1c4C6iWC');
        script.setAttribute('data-mapping', 'pathname');
        script.setAttribute('data-strict', '0');
        script.setAttribute('data-reactions-enabled', '1');
        script.setAttribute('data-emit-metadata', '0');
        script.setAttribute('data-input-position', 'bottom');
        script.setAttribute('data-theme', currentTheme);
        script.setAttribute('data-lang', 'zh-CN');
        script.setAttribute('data-loading', 'lazy'); // 保持延迟加载性能
        script.setAttribute('crossorigin', 'anonymous');
        script.async = true;

        container.innerHTML = '';
        container.appendChild(script);
        giscusLoaded = true;
    }

    // 3. 实时发送更新消息（用于主题切换）
    function updateGiscusTheme() {
        const iframe = document.querySelector('iframe.giscus-frame');
        if (!iframe) return;

        const theme = getGiscusTheme();
        iframe.contentWindow.postMessage(
            { giscus: { setConfig: { theme: theme } } },
            'https://giscus.app'
        );
    }

    // --- 核心控制逻辑 ---

    function initGiscusLogic() {
        giscusLoaded = false; // 页面跳转后重置状态

        // 逻辑：如果页面在顶部，等待 150ms 加载
        // 如果页面不在顶部（比如用户刷新后保持在页面中间），则使用 IntersectionObserver 触发
        
        const triggerLoad = () => {
            if (window.scrollY < 150) {
                // 情况 A：在页面顶部
                // 150ms 正好是 Fuwari 加载蒙版开始消失的时间点
                setTimeout(() => {
                    loadGiscus();
                }, 150);
            }
        };

        // 备选方案：如果用户直接滚到了下面，或者一进来就在下面，进入视口即加载
        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                loadGiscus();
                observer.disconnect();
            }
        }, { rootMargin: '200px' }); // 提前 200px 预加载

        const container = document.getElementById('giscus-container');
        if (container) observer.observe(container);

        // 执行顶部检测
        triggerLoad();
    }

    // 适配 Astro View Transitions 和首次进入
    document.addEventListener('astro:page-load', initGiscusLogic);

    // 主题观察者保持运行
    let debounceTimer;
    const themeObserver = new MutationObserver(() => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(updateGiscusTheme, 200);
    });

    themeObserver.observe(document.documentElement, { 
        attributes: true, 
        attributeFilter: ['class', 'data-theme'] 
    });
</script>